{
  "name": "pug-bem-start-project",
  "version": "3.0.0",
  "description": "Startkit for HTML/CSS/JS pages layout.",
  "author": "Evgeny Ovchinnikov",
  "license": "ISC",
  "main": "gulpfile.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development gulp development",
    "build": "cross-env NODE_ENV=production gulp production",
    "lint:styles": "stylelint --quiet-deprecation-warnings \"src/**/*.scss\"",
    "lint:scripts": "eslint \"src/**/*.js\"",
    "lint:markup": "html-validator '--ignore=Trailing slash on void elements' \"build/**/!(sitemap).html\" --continue",
    "lint:html": "linthtml \"build/**/!(sitemap).html\" --config .linthtmlrc",
    "build:zip": "gulp buildArchive"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not op_mini all",
    "not and_uc > 0",
    "not < 0.2%"
  ],
  "devDependencies": {
    "@htmlacademy/editorconfig-cli": "3.0.0",
    "@prettier/plugin-pug": "3.4.2",
    "browser-sync": "3.0.4",
    "browserslist-to-esbuild": "2.1.1",
    "cpy": "13.2.2",
    "cross-env": "10.1.0",
    "emitty": "1.4.0",
    "eslint": "^10.4.0",
    "eslint-config-htmlacademy": "^11.0.0",
    "get-classes-from-html": "1.0.1",
    "globals": "^17.6.0",
    "gulp": "5.0.1",
    "gulp-data": "1.3.1",
    "gulp-esbuild": "0.14.1",
    "gulp-flatten": "0.4.0",
    "gulp-if": "3.0.0",
    "gulp-notify": "5.0.0",
    "gulp-plumber": "1.2.1",
    "gulp-postcss": "10.0.0",
    "gulp-pretty-html": "2.0.10",
    "gulp-pug": "5.0.0",
    "gulp-sass": "6.0.1",
    "gulp-sharp-responsive": "0.4.1",
    "gulp-stacksvg": "6.0.0",
    "gulp-zip": "6.1.0",
    "linthtml-config-htmlacademy": "2.0.0",
    "mkdirp": "3.0.1",
    "postcss": "8.5.15",
    "postcss-lightningcss": "1.1.0",
    "prettier": "3.8.3",
    "pug": "3.0.4",
    "sass": "1.100.0",
    "stylelint": "17.12.0",
    "stylelint-config-htmlacademy": "5.0.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-order": "8.1.1",
    "w3c-html-validator": "2.2.1"
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.14",
    "accordion-js": "^3.4.1",
    "aos": "^2.3.4",
    "countup.js": "^2.10.0",
    "handy-collapse": "^1.1.0",
    "imask": "^7.6.1",
    "just-validate": "^4.3.0",
    "normalize.css": "^8.0.1",
    "swiper": "^12.1.4",
    "tippy.js": "^6.3.7"
  }
}
